{
  "name": "sucullu-koyu-web",
  "private": true,
  "version": "0.1.0",
  "description": "www.sucullukoyu.com birebir yeniden yapım — Vite + TypeScript multi-page clone",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src tests scripts",
    "format": "prettier --write \"src/**/*\" \"tests/**/*\" \"scripts/**/*\"",
    "format:check": "prettier --check \"src/**/*\" \"tests/**/*\" \"scripts/**/*\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "manifest": "node scripts/build-asset-manifest.mjs",
    "verify:assets": "node scripts/verify-assets.mjs"
  },
  "dependencies": {
    "hls.js": "1.4.12"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@playwright/test": "1.52.0",
    "@types/node": "^22.15.21",
    "eslint": "9.27.0",
    "happy-dom": "^17.4.7",
    "pixelmatch": "7.1.0",
    "pngjs": "7.0.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "vite": "6.3.5",
    "vitest": "3.1.4"
  }
}
